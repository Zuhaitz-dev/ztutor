# Hex-encoded Ed25519 public key used to verify license files.
# Leave empty for free-tier/local testing; set this for licensed deployments.
ZTUTOR_LICENSE_PUBKEY=

# Optional: override where the server stores its DB, SSH host key, and license.
# ZTUTOR_DATA_DIR=/data

# Optional: explicit license file path inside the container or host.
# ZTUTOR_LICENSE_FILE=/data/license.key

# Optional: shared token for the remote execution server.
# ZTUTOR_EXEC_TOKEN=
